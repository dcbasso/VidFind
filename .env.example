# Caminho absoluto para a pasta raiz do acervo de vídeos
VIDEOS_PATH=/caminho/para/seus/videos

# Subpasta a processar dentro de VIDEOS_PATH (deixe vazio para processar tudo)
VIDEO_SCAN_SUBDIR=

# Chave de acesso ao Meilisearch — use uma string longa e aleatória
MEILI_MASTER_KEY=troque-por-chave-segura

# Modelo LLaVA usado pelo Ollama para descrever cenas (padrão: llava:13b)
# Opções: llava:7b (mais rápido, menor qualidade), llava:13b, llava:34b (mais lento, maior qualidade)
OLLAMA_MODEL=llava:13b

# Intervalo em segundos entre frames analisados pelo LLaVA (padrão: 10)
TIMEBOX_INTERVAL=10

# URL do Ollama (padrão aponta para o container Docker)
# Se usar Ollama instalado na máquina host: http://host-gateway:11434
OLLAMA_URL=http://ollama:11434
